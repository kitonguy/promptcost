# =============================================================================
# REDIRECT RULES — Cloudflare Pages
# OLD URLs → /en/ prefixed structure
# IMPORTANT: Rules are processed top-to-bottom. More specific rules MUST come first.
# =============================================================================

# STATIC ASSETS — These MUST come first (before /en/* skip)
# Serve directly with 200, don't redirect
/_astro/*         /_astro/:splat          200
/images/*        /images/:splat           200
/fonts/*         /fonts/:splat            200
/favicon.svg     /favicon.svg            200
/logo.svg        /logo.svg               200
/og-image.svg    /og-image.svg           200
/sitemap.xml     /sitemap.xml            200
/llms.txt        /llms.txt              200
/robots.txt      /robots.txt            200

# Root to /en/
/                /en/                    301

# Blog old structure — all variants → trailing slash /en/
/blog/           /en/blog/               301
/blog            /en/blog/               301
/blog/*          /en/blog/:splat/        301

# GPU page — all variants → trailing slash /en/
/gpu/            /en/gpu/                301
/gpu             /en/gpu/                301

# Skip /en/* paths — they are real pages, not redirects (stops /en/en/ loop)
/en/*            /en/:splat              200

# Catch-all for non-en paths only
/*               /en/:splat              301
