<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <rect fill="#1c1917" width="1200" height="630"/>
  <text x="600" y="150" font-family="system-ui" font-size="42" fill="#eab308" text-anchor="middle" font-weight="bold">AI Pricing Secrets</text>
  <text x="600" y="220" font-family="system-ui" font-size="24" fill="#fde047" text-anchor="middle">How Providers Set Prices</text>
  <rect x="200" y="280" width="250" height="100" rx="8" fill="#a16207"/>
  <text x="325" y="330" font-family="system-ui" font-size="18" fill="white" text-anchor="middle">Token-Based</text>
  <text x="325" y="360" font-family="system-ui" font-size="14" fill="#fef08a" text-anchor="middle">Per-million pricing</text>
  <rect x="475" y="280" width="250" height="100" rx="8" fill="#ca8a04"/>
  <text x="600" y="330" font-family="system-ui" font-size="18" fill="white" text-anchor="middle">Volume Discounts</text>
  <text x="600" y="360" font-family="system-ui" font-size="14" fill="#fef08a" text-anchor="middle">Enterprise tiers</text>
  <rect x="750" y="280" width="250" height="100" rx="8" fill="#a16207"/>
  <text x="875" y="330" font-family="system-ui" font-size="18" fill="white" text-anchor="middle">Context Window</text>
  <text x="875" y="360" font-family="system-ui" font-size="14" fill="#fef08a" text-anchor="middle">Bigger = pricier</text>
  <text x="600" y="480" font-family="system-ui" font-size="24" fill="#eab308" text-anchor="middle">Knowledge is Savings</text>
</svg>
