<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <rect fill="#064e3b" width="1200" height="630"/>
  <text x="600" y="150" font-family="system-ui" font-size="48" fill="#34d399" text-anchor="middle" font-weight="bold">AI API Cost Reduction</text>
  <text x="600" y="230" font-family="system-ui" font-size="28" fill="#6ee7b7" text-anchor="middle">Production Optimization System</text>
  <text x="600" y="290" font-family="system-ui" font-size="24" fill="#a7f3d0" text-anchor="middle">Tiered Routing + Caching + Compression</text>
  <rect x="200" y="350" width="200" height="80" rx="8" fill="#059669"/>
  <text x="300" y="395" font-family="system-ui" font-size="18" fill="white" text-anchor="middle">Routing</text>
  <rect x="500" y="350" width="200" height="80" rx="8" fill="#047857"/>
  <text x="600" y="395" font-family="system-ui" font-size="18" fill="white" text-anchor="middle">Caching</text>
  <rect x="800" y="350" width="200" height="80" rx="8" fill="#065f46"/>
  <text x="900" y="395" font-family="system-ui" font-size="18" fill="white" text-anchor="middle">Compression</text>
  <rect x="350" y="480" width="500" height="80" rx="8" fill="#047857"/>
  <text x="600" y="525" font-family="system-ui" font-size="24" fill="white" text-anchor="middle">60% Cost Reduction</text>
</svg>
