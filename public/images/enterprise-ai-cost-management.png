<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <rect fill="#1c1917" width="1200" height="630"/>
  <text x="600" y="150" font-family="system-ui" font-size="42" fill="#f97316" text-anchor="middle" font-weight="bold">Enterprise AI Cost Control</text>
  <text x="600" y="220" font-family="system-ui" font-size="24" fill="#fdba74" text-anchor="middle">Budget Management at Scale</text>
  <rect x="150" y="280" width="230" height="120" rx="8" fill="#c2410c"/>
  <text x="265" y="335" font-family="system-ui" font-size="18" fill="white" text-anchor="middle">Per-User Limits</text>
  <text x="265" y="370" font-family="system-ui" font-size="14" fill="#fed7aa" text-anchor="middle">Control individual spend</text>
  <rect x="420" y="280" width="230" height="120" rx="8" fill="#ea580c"/>
  <text x="535" y="335" font-family="system-ui" font-size="18" fill="white" text-anchor="middle">Cost Monitoring</text>
  <text x="535" y="370" font-family="system-ui" font-size="14" fill="#fed7aa" text-anchor="middle">Real-time dashboards</text>
  <rect x="690" y="280" width="230" height="120" rx="8" fill="#c2410c"/>
  <text x="805" y="335" font-family="system-ui" font-size="18" fill="white" text-anchor="middle">Alert System</text>
  <text x="805" y="370" font-family="system-ui" font-size="14" fill="#fed7aa" text-anchor="middle">Budget thresholds</text>
  <rect x="350" y="440" width="500" height="80" rx="8" fill="#9a3412"/>
  <text x="600" y="485" font-family="system-ui" font-size="20" fill="white" text-anchor="middle">Prevent Cost Overruns</text>
</svg>
