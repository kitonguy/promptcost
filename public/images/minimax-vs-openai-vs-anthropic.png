<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <rect fill="#1a1a2e" width="1200" height="630"/>
  <text x="600" y="180" font-family="system-ui" font-size="48" fill="#f472b6" text-anchor="middle" font-weight="bold">MiniMax vs OpenAI</text>
  <text x="600" y="250" font-family="system-ui" font-size="24" fill="#f9a8d4" text-anchor="middle">Asian AI Competition 2026</text>
  <rect x="200" y="320" width="350" height="120" rx="12" fill="#ec4899"/>
  <text x="375" y="375" font-family="system-ui" font-size="28" fill="white" text-anchor="middle">MiniMax</text>
  <text x="375" y="410" font-family="system-ui" font-size="18" fill="#fce7f3" text-anchor="middle">$0.10/M tokens</text>
  <rect x="650" y="320" width="350" height="120" rx="12" fill="#be185d"/>
  <text x="825" y="375" font-family="system-ui" font-size="28" fill="white" text-anchor="middle">OpenAI</text>
  <text x="825" y="410" font-family="system-ui" font-size="18" fill="#fce7f3" text-anchor="middle">$2.50/M tokens</text>
  <text x="600" y="520" font-family="system-ui" font-size="24" fill="#f472b6" text-anchor="middle">25x Price Difference</text>
</svg>
