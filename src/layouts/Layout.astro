---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: object | object[];
  article?: {
    published_date: string;
    updated_date?: string;
    author: string;
    category: string;
  };
}

const {
  title,
  description,
  canonical = 'https://promptcost.org',
  ogImage = '/og-image.svg',
  schema,
  article
} = Astro.props;

const siteUrl = 'https://promptcost.org';
const fullTitle = title.includes('PromptCost') ? title : `${title} | PromptCost.org`;

// SoftwareApplication Schema (always available)
const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "PromptCost.org",
  "url": siteUrl,
  "description": "Real-time AI Token Estimation & Global Model Cost Comparison Tool",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Web Browser",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "reviewCount": "127"
  }
};

// WebSite + Organization schema for non-article pages
const websiteSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "name": "PromptCost.org",
      "url": siteUrl,
      "description": "Real-time AI token estimation and global model cost comparison tool. Compare 200+ AI model prices instantly.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": `${siteUrl}/?q={search_term_string}`
        },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Organization",
      "name": "PromptCost.org",
      "url": siteUrl,
      "logo": `${siteUrl}/logo.svg`,
      "description": "Free AI cost estimation and model comparison platform. Helping developers and businesses optimize AI spending.",
      "sameAs": ["https://twitter.com/promptcost"]
    }
  ]
};

// FAQPage Schema for homepage FAQ section
const homepageFaqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does GPT-4o cost per 1M tokens?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "GPT-4o costs approximately $2.50 per million input tokens and $10.00 per million output tokens as of April 2026. Prices vary by provider - check PromptCost.org for real-time pricing from multiple sources."
      }
    },
    {
      "@type": "Question",
      "name": "How is token count calculated?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tokens are calculated by dividing text character count by approximately 4 (since 1 token ≈ 4 characters in English). For most LLMs, 1,000 tokens equal about 750 words."
      }
    },
    {
      "@type": "Question",
      "name": "What is the cheapest AI model?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The cheapest AI models as of April 2026 include DeepSeek V3 at $0.01/M tokens and various open-source models under $0.50/M tokens. Use PromptCost.org to compare 200+ models in real-time."
      }
    }
  ]
};

// Build schema list for output — WebSite, Organization, SoftwareApplication as SEPARATE blocks
// This allows Google Search Console to show sitelinks search box
let schemaList: object[] = [];

if (article) {
  // Article page: BlogPosting schema (or passed schema), breadcrumb, organization
  if (schema) {
    schemaList = Array.isArray(schema) ? [...schema] : [schema];
  } else {
    schemaList = [softwareSchema];
  }
} else {
  // Non-article page: SEPARATE blocks — SoftwareApplication + WebSite + Organization + FAQ
  // This enables sitelinks search box in Google Search Console
  schemaList = [softwareSchema, homepageFaqSchema];

  // Add WebSite as its own separate block (not inside @graph)
  const websiteSchemaStandalone = {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "PromptCost.org",
    "url": siteUrl,
    "description": "Real-time AI token estimation and global model cost comparison tool. Compare 200+ AI model prices instantly.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": `${siteUrl}/?q={search_term_string}`
      },
      "query-input": "required name=search_term_string"
    }
  };
  schemaList.push(websiteSchemaStandalone);

  // Add Organization as its own separate block
  const orgSchemaStandalone = {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "PromptCost.org",
    "url": siteUrl,
    "logo": `${siteUrl}/logo.svg`,
    "description": "Free AI cost estimation and model comparison platform. Helping developers and businesses optimize AI spending.",
    "sameAs": ["https://twitter.com/promptcost"]
  };
  schemaList.push(orgSchemaStandalone);
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  <title>{fullTitle}</title>
  <meta name="description" content={description}>
  <meta name="author" content={article?.author || 'PromptCost.org'}>
  <link rel="canonical" href={canonical}>

  {/* hreflang for internationalization */}
  <link rel="alternate" hreflang="en" href={canonical}>
  <link rel="alternate" hreflang="x-default" href="https://promptcost.org/">

  {/* Open Graph */}
  <meta property="og:type" content={article ? 'article' : 'website'}>
  <meta property="og:url" content={canonical}>
  <meta property="og:title" content={fullTitle}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`}>
  <meta property="og:site_name" content="PromptCost.org">

  {/* Twitter Card */}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={fullTitle}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`}>

  {/* Article meta tags */}
  {article && (
    <>
      <meta property="article:published_time" content={article.published_date}>
      <meta property="article:modified_time" content={article.updated_date || article.published_date}>
      <meta property="article:author" content={article.author}>
      <meta property="article:section" content={article.category}>
    </>
  )}

  {/* Robots meta for article pages — enable rich snippets */}
  {article && (
    <meta name="robots" content="index, follow, max-snippet:150, max-image-preview:large">
  )}

  {/* News keywords — still read by some crawlers */}
  <meta name="keywords" content="GPT-4o pricing, Claude API cost, AI token calculator, DeepSeek V3 cost, GPU rental comparison, AI cost optimization, model comparison, API pricing 2026">

  {/* Preconnect to external origins for performance */}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  {/* Favicon */}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">

  {/* RSS Autodiscovery */}
  <link rel="alternate" type="application/rss+xml" title="PromptCost.org Blog" href="/rss.xml">

  {/* Schema.org JSON-LD — one block per schema, no duplicates */}
  {schemaList.map((s) => (
    <script type="application/ld+json" is:inline set:html={JSON.stringify(s)}></script>
  ))}

  {/* Critical CSS - Inlined for faster FCP, no external fonts */}
  <style is:inline>
    :root{--primary:#2563eb;--cheaper:#10b981;--expensive:#f59e0b}
    html{scroll-behavior:smooth}
    body{margin:0;padding:0;font-family:system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;background:#f8fafc;color:#1e293b}
    img,svg{max-width:100%;height:auto}
    .min-h-screen{min-height:100vh}
  </style>

  <style is:global>
    @tailwind base;
    @tailwind components;
    @tailwind utilities;

    :root {
      --primary: #2563eb;
      --cheaper: #10b981;
      --expensive: #f59e0b;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      @apply bg-bg text-text antialiased;
    }

    :focus-visible {
      @apply outline-2 outline-offset-2 outline-primary;
    }

    /* Content visibility for long articles — performance */
    article {
      content-visibility: auto;
      contain-intrinsic-size: 1000px;
    }

    ::-webkit-scrollbar {
      width: 8px;
      height: 8px;
    }

    ::-webkit-scrollbar-track {
      @apply bg-slate-100;
    }

    ::-webkit-scrollbar-thumb {
      @apply bg-slate-400 rounded;
    }

    ::-webkit-scrollbar-thumb:hover {
      @apply bg-slate-500;
    }
  </style>
</head>
<body class="min-h-screen bg-bg text-text">
  <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-white focus:font-bold focus:shadow-lg">
    Skip to main content
  </a>

  <header class="border-b border-border bg-white/80 backdrop-blur-sm sticky top-0 z-40">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between" aria-label="Main navigation">
      <a href="/" class="flex items-center gap-3 group">
        <span class="text-2xl font-extrabold text-primary tracking-tight">PromptCost</span>
        <span class="text-xs font-medium text-slate-500">.org</span>
      </a>
      <div class="flex items-center gap-8">
        <a href="/" class="text-base font-bold text-slate-700 hover:text-primary transition-colors">Calculator</a>
        <a href="/en/gpu/" class="text-base font-bold text-slate-700 hover:text-primary transition-colors">GPU Index</a>
        <a href="/en/blog/" class="text-base font-bold text-slate-700 hover:text-primary transition-colors">Blog</a>
        <a href="/#faq" class="text-base font-bold text-slate-700 hover:text-primary transition-colors">FAQ</a>
      </div>
    </nav>
  </header>

  <main id="main-content">
    <slot />
  </main>

  <footer class="border-t border-border bg-white mt-20 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-6">
        <div class="text-center md:text-left">
          <p class="font-bold text-primary text-lg">PromptCost.org</p>
          <p class="text-sm text-slate-500 mt-1">Transparency in Artificial Intelligence</p>
        </div>
        <nav aria-label="Footer navigation">
          <div class="flex gap-6 text-sm text-slate-500">
            <a href="/en/about/" class="hover:text-primary transition-colors">About</a>
            <a href="/en/privacy-policy/" class="hover:text-primary transition-colors">Privacy</a>
            <a href="/en/terms/" class="hover:text-primary transition-colors">Terms</a>
            <a href="/en/contact/" class="hover:text-primary transition-colors">Contact</a>
          </div>
        </nav>
      </div>
      <div class="text-center mt-8 pt-8 border-t border-border">
        <p class="text-sm text-slate-400">&copy; {new Date().getFullYear()} PromptCost.org - All rights reserved.</p>
      </div>
    </div>
  </footer>
</body>
</html>
